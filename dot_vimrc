"key binding for some plugins
nmap <C-s> <Plug>MarkdownPreview

let g:ctrlp_map = '<c-p>'
let g:ctrlp_cmd = 'CtrlP'

color Atelier_ForestDark
map <C-n> :NERDTreeToggle<CR>

"----------------------------------"
"this fixes the indent
set softtabstop=4
set tabstop=4
set shiftwidth=4
set expandtab
set clipboard=unnamed

"----------------------------------"
"Code autocompletion, https://github.com/neoclide/coc.nvim to see more

"Trigger completion
inoremap <silent><expr> <TAB>
      \ pumvisible() ? "\<C-n>" : "\<TAB>"

"Go to definition
nmap <silent> gd <Plug>(coc-definition)

"Hover docs
nmap <silent> K :call CocActionAsync('doHover')<CR>


function! Get_random_offset(max) abort
  return str2nr(matchstr(reltimestr(reltime()), '\.\zs\d\+')[1:]) % a:max
endfunction

"----------------------------------"
"this autocompletes stuff
inoremap " ""<left>
inoremap ' ''<left>
inoremap ( ()<left>
inoremap [ []<left>
inoremap { {}<left>
inoremap {<CR> {<CR>}<ESC>O
inoremap {;<CR> {<CR>};<ESC>O

